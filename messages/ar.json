  "Terms": {
    "badge": "شروط الخدمة",
    "title": "شروط الخدمة",
    "updated": "آخر تحديث: 1 يناير 2025 • تاريخ البدء: 1 يناير 2025",
    "intro": "من خلال الوصول إلى رنت هب أو استخدامه، فإنك توافق على الالتزام بالشروط والأحكام التالية. يرجى قراءتها بعناية قبل إجراء أي حجوزات أو استخدام أي ميزات للمنصة.",
    "sections": {
      "s1": {
        "title": "الموافقة على الشروط",
        "content": "من خلال الوصول إلى رنت هب، فإنك تؤكد أنك تبلغ من العمر 18 عاماً على الأقل وتوافق على هذه الشروط. إذا كنت لا توافق، يجب عليك عدم استخدام المنصة."
      },
      "s2": {
        "title": "استخدام المنصة",
        "content": "تمنحك رنت هب ترخيصاً محدوداً وغير حصري وغير قابل للتحويل للوصول إلى المنصة للاستخدام الشخصي وغير التجاري. لا يجوز لك كشط أو نسخ أو إعادة إنتاج المحتوى دون إذن كتابي."
      },
      "s3": {
        "title": "حسابات المستخدمين",
        "content": "أنت مسؤول عن الحفاظ على سرية بيانات اعتماد حسابك. وتوافق على إخطارنا فوراً بأي استخدام غير مصرح به لحسابك."
      },
      "s4": {
        "title": "الحجوزات والمدفوعات",
        "content": "تخضع جميع الحجوزات لتأكيد التوفر. تتم معالجة الدفع بشكل آمن من خلال Stripe. تطبق رنت هب رسوم خدمة على كل معاملة، ويتم عرض سعرها عند الدفع.",
        "note": "لا يتم تأكيد الحجوزات إلا بعد معالجة الدفع بنجاح. الحجوزات المعلقة لا تضمن التوفر."
      },
      "s5": {
        "title": "سياسة الإلغاء",
        "content": "تختلف شروط الإلغاء حسب القائمة. يتم عرض السياسة المعمول بها في كل صفحة قائمة وفي خطوة تأكيد الحجز. رسوم خدمة رنت هب غير قابلة للاسترداد ما لم ينص على خلاف ذلك."
      },
      "s6": {
        "title": "مسؤوليات المضيف",
        "content": "يتحمل المضيفون (مديرو القوائم) مسؤولية دقة قوائمهم، وحالة العقار أو المركبة، والامتثال لجميع القوانين واللوائح المحلية."
      },
      "s7": {
        "title": "السلوك المحظور",
        "content": "يجب على المستخدمين عدم:",
        "list": [
          "تقديم معلومات كاذبة أو مضللة",
          "استخدام المنصة لأي غرض غير قانوني",
          "محاولة التحايل على المنصة للحجز مباشرة وتجنب الرسوم",
          "مضايقة أو تهديد مستخدمين آخرين أو مضيفين"
        ]
      },
      "s8": {
        "title": "الملكية الفكرية",
        "content": "جميع المحتويات الموجودة على رنت هب، بما في ذلك الشعارات والنصوص والتصميم، هي ملك لشركة رنت هب. لا يجوز لك إعادة إنتاج أو توزيع أي محتوى دون موافقة كتابية."
      },
      "s9": {
        "title": "تحديد المسؤولية",
        "content": "رنت هب هي منصة سوق وليست مسؤولة عن تصرفات المضيفين، أو حالة القوائم، أو أي أضرار تنشأ عن الحجوزات التي تتم من خلال المنصة."
      },
      "s10": {
        "title": "الخصوصية والبيانات",
        "content": "يخضع استخدامك للمنصة أيضاً لسياسة الخصوصية الخاصة بنا. باستخدامك لرنت هب، فإنك توافق على جمع بياناتك واستخدامها كما هو موضح فيها."
      },
      "s11": {
        "title": "التغييرات على الشروط",
        "content": "تحتفظ رنت هب بالحق في تحديث هذه الشروط في أي وقت. ويشكل استمرار استخدام المنصة بعد التغييرات موافقتك على الشروط المحدثة."
      },
      "s12": {
        "title": "الاتصال والنزاعات",
        "content": "لأي أسئلة بخصوص هذه الشروط، يرجى الاتصال بنا على legal@renthub.com. سيتم حل النزاعات بموجب قوانين الجزائر."
      }
    }
